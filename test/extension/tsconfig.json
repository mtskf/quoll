{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
    "lib": ["es2022"],
    "types": ["node", "vscode", "mocha"],
    "outDir": "../../out/test-e2e",
    "rootDir": ".",
    "noEmit": false,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": false
  },
  "include": ["launch.ts", "e2e/**/*.ts"]
}
