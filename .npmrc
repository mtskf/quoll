# Hoist @types/* to the root node_modules so TypeScript's default
# `node` module resolution finds transitive type packages
# (pnpm v10 does not hoist @types/* by default — when a top-level
# @types/* package depends on another @types/* package, tsc otherwise
# fails with TS7016).
#
# This is a hoist policy adjustment, not a new dependency.
public-hoist-pattern[]=@types/*
